{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:5173",
          "https://strata-audio.de",
          "https://www.strata-audio.de"
        ],
        "methods": [
          "GET",
          "PUT",
          "POST",
          "DELETE",
          "HEAD"
        ],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3000
    }
  ]
}